---
import { Image } from 'astro:assets';
import dr from '../assets/dr.jpg'
---
<section class="hero">
    <div class="content">
        <p class="greeting">Hi! I'm Diego Rivera</p>
        <h1 class="position"><span>Software Developer</span></h1>
        <p class="description">
            Currently studying my 5th semester, I like to travel, listen music and drink coffee.</p>
            <p class="description">My interests are: Backend and mobile apps.
            Very soon I will do my last year especializing in DevOps, hope we can connect soon!
            </p>
        </p>
        <p></p>
    </div>

    <div class="image-container">
        <Image src={dr} alt="Diego Rivera">
    </div>
</section>

<style>
    .image-container{
        flex: 0 0 auto;
    }
    .image-container img {
    width: 250px;           
    height: 250px;
    border-radius: 50%;
    object-fit: cover;
    box-shadow: 0 0 50px rgba(255, 255, 255, 0.05);
    }
    .hero{
        display: flex;
        justify-content: center;
        display: flex;
        align-items: center;
        justify-content: center; 
        gap: 100px;             
        min-height: 80vh;
        padding: 0 20px;
        max-width: 1200px;      
        margin: 0 auto;
    }
    .greeting{
        color: white;
        font-weight: bolder;
    }
    .position{
        color:white;
    }
    .description{
        color:white;
        text-align: justify;
    }
    .hero{
        display: flex;
        align-items: center;
        justify-content: space-around;
        padding: 100px 20px;
        min-height: 40vh;
    }
    .content{
        flex: 1;            
        max-width: 500px;
    }
    p{
        font-size: 18px;
    }

    @media (max-width: 1024px) {
    .hero {
        gap: 50px;
        padding: 80px 20px;
    }

    .image-container img {
        width: 320px;
        height: 320px;
    }

    .content {
        max-width: 450px;
    }

    p {
        font-size: 16px;
    }
    }

    @media (max-width: 768px) {
    .hero {
        flex-direction: column;
        gap: 30px;
        padding: 60px 20px;
        min-height: auto;
    }

    .image-container {
        flex: none;
    }

    .image-container img {
        width: 250px;
        height: 280px;
    }

    .content {
        max-width: 100%;
        width: 100%;
    }

    .greeting {
        font-size: 1.2rem;
    }

    .position {
        font-size: 1.8rem;
    }

    p {
        font-size: 15px;
    }
    }

    @media (max-width: 480px) {
    .hero {
        flex-direction: column;
        gap: 20px;
        padding: 40px 15px;
        min-height: auto;
    }

    .image-container img {
        width: 220px;
        height: 220px;
    }

    .content {
        max-width: 100%;
    }

    .greeting {
        font-size: 1rem;
    }

    .position {
        font-size: 1.5rem;
    }

    p {
        font-size: 14px;
    }

    .description {
        text-align: left;
    }
    }
    

</style>