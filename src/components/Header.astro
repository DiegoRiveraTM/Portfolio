---
import Projects from "./Projects.astro"
---

<nav>
    <ul class="container">
        <li class="header"><a href="#home">Home</a></li>
        <li class="header"><a href="#projects">Projects</a></li>
        <li class="header"><a href="#contact">Contact Me</a></li>
    </ul>
</nav>

<style>
    .container{
        display: flex;
        gap: 40px;
        justify-content: center;
        background-color: rgba(255, 255, 255, 0.021);
        backdrop-filter: blur(12px);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 50px;
        padding: 10px 30px;
        position: sticky;
        top: 20px;
        margin: 20px auto;
        text-decoration: none;
        width: max-content;
        transition: all 0.3s ease;
        color: white;
    }
    .header{
        display: flex;
        gap: 40px;
        color: white; 
        cursor: pointer;
        font-style: DM-Sans;
    }

    container a{
        text-decoration: none;
        color: white;
    }
    .header a:visited{
        color: white;
    }
    .header a {
        text-decoration: none;
    }

    @media (max-width: 768px) {
    .container {
        gap: 20px;
        padding: 8px 20px;
        flex-wrap: wrap;
        top: 10px;
        margin: 10px auto;
    }
    

    .header {
        gap: 20px;
        font-size: 0.9rem;
    }

    container a{
        text-decoration: none;
        color: white;
    }
    .header a:visited{
        color: white;
    }
    .header a {
        text-decoration: none;
    }

    }

    @media (max-width: 480px) {
    .container {
        gap: 15px;
        padding: 8px 15px;
        flex-wrap: wrap;
        top: 5px;
        margin: 5px auto;
        border-radius: 40px;
    }

    .header {
        gap: 15px;
        font-size: 0.8rem;
    }

    container a{
        text-decoration: none;
        color: white;
    }
    .header a:visited{
        color: white;
    }
    .header a {
        text-decoration: none;
    }
    
    }
    
</style>