---
import github from '../../public/svg/github.svg';
import java from '../../public/svg/java.svg';
import react from '../../public/svg/react.svg';
import mysql from '../../public/svg/mysql.svg';
import express from '../../public/svg/express.svg';
import typescript from '../../public/svg/typescript.svg';
import css from '../../public/svg/css.svg';
import kotlin from '../../public/svg/kotlin.svg';
import postgresql from '../../public/svg/postgresql.svg';
import sqlite from '../../public/svg/sqlite.svg';
import tailwindcss from '../../public/svg/tailwindcss.svg';
import docker from '../../public/svg/docker.svg';
import mongodb from '../../public/svg/mongodb.svg';
import nextjs from '../../public/svg/nextjs.svg';

const tags = [
    {
        name: "React",
        icon: react,
        color: '#61DAFB'
    },
    {
        name: "Java",
        icon: java,
        color: '#007396'
    },
    {
        name: "TypeScript",
        icon: typescript,
        color: '#3178C6'
    },
    {
        name: "Css",
        icon: css,
        color: '#1572B6'
    },
    {
        name: "Express",
        icon: express,
        color: '#000000'
    },
    {
        name: "MySQL",
        icon: mysql,
        color: '#4479A1'
    },
    {
        name: "Kotlin",
        icon: kotlin,
        color: '#0095D5'
    },
    {
        name: "PostgreSQL",
        icon: postgresql,
        color: '#336791'
    },
    {
        name: "GitHub",
        icon: github,
        color: '#181717'
    },
    {
        name: "SQLite",
        icon: sqlite,
        color: '#003B57'
    },
    {
        name: "Tailwind CSS",
        icon: tailwindcss,
        color: '#06B6D4'
    }, 
    {
        name: "Docker",
        icon: docker,
        color: '#2496ED'
    },
    {
        name: "MongoDB",
        icon: mongodb,
        color: '#47A248'
    },
    {
        name: "Next.js",
        icon: nextjs,
        color: '#000000'
        
    }
]

const projects = [
    {
        name: "Kotlin Android App",
        description: "A wallet in kotlin to manage your money, simulate investments and check top 10 cryptocurrencies.",
        status: "Finished (not deployed)",
        link: "https://github.com/DiegoRiveraTM/Wallet-Kotlin",
        icon: github,
        image: "/projects/Wallet.png",
        tags: [tags[6], tags[9]],
        github: "https://github.com/DiegoRiveraTM/Wallet-Kotlin"
    },
    {
        name: "Shift Manager",
        description: "A react native app to manage your workers shifts, this app was made for a business in Vancouver",
        status: "In development",
        link: "https://github.com/DiegoRiveraTM/mobileApp",
        icon: github,
        image: "/projects/shift.png",
        tags: [tags[3], tags[4], tags[7], tags[0], tags[2], tags[11]],
        github: "https://github.com/DiegoRiveraTM/mobileApp"
    },
    {
        name: "TecmiDoc",
        description: "A Java desktop app to make medical appointements and manage patients, this app was made for a final project of the bases de datos class.",
        status: "Finished (not deployed)",
        link: "https://github.com/DiegoRiveraTM/TecmiDoc",
        icon: github,
        image: "/projects/javafx.jpg",
        tags: [tags[1], tags[5]],
        github: "https://github.com/DiegoRiveraTM/TecmiDoc"
    },
    {
        name: "NovaBank",
        description: "A react web app to manage your money, simulate transactions, made it for the final project of DevOps class, the app is not deployed and the intention was to deploy it using AWS.",
        status: "In development",
        link: "https://github.com/DiegoRiveraTM/NovaBank",
        icon: github,
        image: "/projects/nova.jpg",
        tags: [tags[4], tags[0], tags[3], tags[2], tags[12]],
        github: "https://github.com/DiegoRiveraTM/NovaBank"
    },
    {
        name: "Clothing Store",
        description: "Web app to simulate a clothing store e-commerce, this app was made for a final project of the fullstack course.",
        status: "Finished (not deployed)",
        link: "https://github.com/DiegoRiveraTM/Tienda-Ropa-FS",
        icon: github,
        image: "/projects/tdrp.png",
        tags: [tags[0], tags[2], tags[3], tags[12], tags[13]],
        github: "https://github.com/DiegoRiveraTM/Tienda-Ropa-FS"
    }

]
---

<section id="projects" class="projects-grid">
{
    projects.map(({ name, image, tags, github, icon, description, status}) => (
    <article class="project-card">
        <div class="project-image-container">
        <div class="blur-background" style={`background-image: url(${image})`}></div>
        <div class="project-image-wrapper">
            <img alt={name} class="project-img" loading="lazy" src={image} />
            {github && (
            <a href={github} class="github-overlay-link" target="_blank">
                <span class="icon-code">{"</>"}</span>
            </a>
            )}
        </div>
        </div>

        <div class="project-info">
        <h3 class="project-title">{name}</h3>
        <p class="project-description">{description}</p>
        <p class="project-status">{status}</p>
        <ul class="tags-list">
            {tags.map((tag) => (
            <li class="tag-item">
                <img src={tag.icon.src} alt={tag.name} class="tag-icon-img" />
                <span class="tag-name">{tag.name}</span>
            </li>
            ))}
        </ul>
        </div>
    </article>
    ))
}
</section>

<style>
    .projects-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2.5rem;
    padding: 2rem;
    max-width: 1200px;
    margin: 0 auto;
    margin: 100px auto 0 auto;
    scroll-margin-top: 120px;
    }

    .project-card {
    display: flex;
    flex-direction: column;
    background: rgba(255, 255, 255, 0.03);
    border-radius: 16px;
    padding: 1rem;
    transition: transform 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    border: 1px solid rgba(255, 255, 255, 0.05);
    }

    .project-description {
        color: white;
        display: -webkit-box;
        overflow: hidden;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;
    }

    .project-status {
        color: white;
        display: -webkit-box;
        overflow: hidden;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;
        font-style: oblique;
    }
    .project-image-container {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9; 
    border-radius: 12px;
    overflow: hidden;
    background: rgba(255, 255, 255, 0.05);
    display: flex;
    justify-content: center;
    align-items: center;
    }

    .blur-background {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    filter: blur(25px);
    opacity: 0.15;
    transform: scale(1.1);
    }

    .project-image-wrapper {
    position: relative;
    z-index: 1;
    width: 100%;      
    height: 100%;      
    background: transparent; 
    padding: 0;        
    display: flex;
    justify-content: center;
    align-items: center;
    }

    .project-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    object-fit: contain;
    object-position: center;
    
    }

    .project-info {
    text-align: center;
    margin-top: 1.5rem;
    }

    .project-title {
    color: white;
    font-size: 1.1rem;
    margin-bottom: 1rem;
    opacity: 0.9;
    }

    .tags-list {
    display: flex;
    justify-content: center;
    gap: 1rem;
    list-style: none;
    padding: 0;
    }

    .tag-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    }

    .tag-icon-img {
    width: 24px;
    height: 24px;
    color: #a5b4fc;
    object-fit: contain;
    filter: drop-shadow(0 0 5px rgba(255,255,255,0.2));
    }

    .tag-name {
    color: #9ca3af;
    font-size: 0.75rem;
    }

    .project-card:hover {
    transform: translateY(-10px);
    }

    .project-card:hover .project-image-wrapper {
    transform: scale(1.05);
    }

    @media (max-width: 768px) {
    .projects-grid {
        scroll-margin-top: 90px;
    }
    }

    @media (max-width: 480px) {
    .projects-grid {
        scroll-margin-top: 80px;
    }
    }

    .github-overlay-link {
    position: absolute;
    bottom: 10px; 
    right: 10px;  
    background: rgba(26, 30, 58, 0.9); 
    color: white;
    width: 32px;  
    height: 32px; 
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 6px;
    font-size: 0.8rem; 
    text-decoration: none;
    border: 1px solid rgba(255,255,255,0.1);
    box-shadow: 0 4px 10px rgba(0,0,0,0.3);
    transition: all 0.2s ease;
    z-index: 10;
    }

    .github-overlay-link:hover {
    background: #2d3463;
    transform: scale(1.1);
    }

    @media (max-width: 1024px) {
    .projects-grid {
        grid-template-columns: repeat(2, 1fr);
        gap: 2rem;
        padding: 1.5rem;
        margin: 80px auto 0 auto;
    }

    .project-title {
        font-size: 1rem;
    }

    .tag-icon-img {
        width: 20px;
        height: 20px;
    }

    .tag-name {
        font-size: 0.65rem;
    }
    }

    @media (max-width: 768px) {
    .projects-grid {
        grid-template-columns: 1fr;
        gap: 1.5rem;
        padding: 1rem;
        margin: 60px auto 0 auto;
    }

    .project-card {
        padding: 0.75rem;
    }

    .project-image-container {
        aspect-ratio: 16 / 10;
    }

    .project-title {
        font-size: 1rem;
        margin-bottom: 0.75rem;
    }

    .project-description {
        font-size: 0.9rem;
        -webkit-line-clamp: 3;
    }

    .project-status {
        font-size: 0.85rem;
    }

    .project-info {
        margin-top: 1rem;
    }

    .tags-list {
        gap: 0.75rem;
        flex-wrap: wrap;
    }

    .tag-icon-img {
        width: 18px;
        height: 18px;
    }

    .tag-name {
        font-size: 0.6rem;
    }

    .github-overlay-link {
        width: 28px;
        height: 28px;
        font-size: 0.7rem;
    }
    }

    @media (max-width: 480px) {
    .projects-grid {
        grid-template-columns: 1fr;
        gap: 1rem;
        padding: 0.75rem;
        margin: 80px auto 0 auto;
    }

    .project-card {
        padding: 0.5rem;
    }

    .project-title {
        font-size: 0.9rem;
        margin-bottom: 0.5rem;
    }

    .project-description {
        font-size: 0.8rem;
        -webkit-line-clamp: 3;
    }

    .project-status {
        font-size: 0.75rem;
    }

    .project-info {
        margin-top: 0.75rem;
    }

    .tags-list {
        gap: 0.5rem;
    }

    .tag-icon-img {
        width: 16px;
        height: 16px;
    }

    .tag-name {
        font-size: 0.55rem;
    }

    .github-overlay-link {
        width: 24px;
        height: 24px;
        font-size: 0.6rem;
        bottom: 5px;
        right: 5px;
    }
    }

</style>